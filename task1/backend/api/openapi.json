      }
    },
    "schemas": {
      "Message": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "AthleteInput": {
        "type": "object",
        "required": ["name", "surname", "birth_date", "birth_place", "birth_country"],
        "properties": {
          "name": { "type": "string" },
          "surname": { "type": "string" },
          "birth_date": { "type": "string", "format": "date", "description": "Supports d/m/Y, d/m/y, or standard formats" },
          "birth_place": { "type": "string" },
          "birth_country": { "type": "string" },
          "death_date": { "type": "string", "format": "date", "nullable": true },
          "death_place": { "type": "string", "nullable": true },
          "death_country": { "type": "string", "nullable": true }
        }
      },
      "AthleteRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "surname": { "type": "string" },
          "year": { "type": "integer" },
          "type": { "type": "string", "enum": ["LOH", "ZOH"] },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "discipline": { "type": "string" },
          "placing": { "type": "integer" }
        }
      }
    }
  }
